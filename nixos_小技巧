#noctalia 启动器打开命令
noctalia-shell ipc call launcher toggle


# 1. 在 dy 主目录创建配置目录
mkdir -p ~/nixos-config

# 2. 复制所有配置
sudo cp -r /e/nixos/* ~/nixos-config/

# 3. 修改所有权
sudo chown -R dy:users ~/nixos-config

# 4. 在用户目录下重建
cd ~/nixos-config
sudo nixos-rebuild switch --flake .#dynx