# 1. 在家目录创建配置文件夹
mkdir -p ~/nixos-config

# 2. 复制现有配置
sudo cp -r /etc/nixos/* ~/nixos-config/
sudo chown -R $USER:$USER ~/nixos-config

# 3. 创建符号链接
sudo rm -rf /etc/nixos/*
sudo ln -sf ~/nixos-config/* /etc/nixos/

# 4. 重建系统
sudo nixos-rebuild switch



